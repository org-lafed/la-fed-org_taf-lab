@startuml
title Sequence - Home Page Smoke Execution

skinparam shadowing false

actor "TestNG" as T
participant "BaseUiTest" as BUT
participant "ConfigManager" as CM
participant "DriverManager" as DM
participant "DriverFactory" as DF
participant "HomePageSmokeTest" as TEST
participant "HomePage" as HP
participant "CookieConsentComponent" as CCC
participant "HeaderComponent" as HC
participant "Automation Exercise UI" as UI

T -> BUT : setUpUiTest()
BUT -> CM : getConfig()
CM --> BUT : ExecutionConfig
BUT -> DM : createDriver(config)
DM -> DF : createDriver(config)
DF --> DM : WebDriver
DM --> BUT : WebDriver

T -> TEST : shouldLoadHomePageAndDisplayCoreNavigation()
TEST -> HP : open()
HP -> UI : GET /
UI --> HP : home page DOM
TEST -> CCC : acceptIfPresent()
TEST -> HP : isLoaded()
HP -> HC : isLogoVisible()
HP -> HC : hasCoreNavigationLinks()
TEST -> HP : isHeroBannerVisible()
TEST -> HP : title()

T -> BUT : tearDownUiTest()
BUT -> DM : quitDriver()

@enduml
