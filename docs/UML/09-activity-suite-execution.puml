@startuml
title Activity - Suite Execution Flow

skinparam shadowing false

start
:Select suiteXmlFile;
:Load ExecutionConfig;

if (Execution context?) then (Local)
  :Initialize local Maven/TestNG run;
  if (Suite type?) then (UI)
    :Create WebDriver;
    :Run UI tests;
    :Capture screenshot on failure if enabled;
    :Quit driver;
  elseif (API)
    :Create API client;
    :Run API tests;
  else (Full / E2E mix)
    :Create WebDriver and API client;
    :Run smoke, UI, and API suites;
    :Execute E2E placeholder if selected;
    :Mark skipped scenarios explicitly when not stabilized;
    :Quit driver;
  endif
elseif (CI)
  :Resolve env=ci inputs;
  :Initialize headless pipeline run;
  if (Suite type?) then (UI/API)
    :Run selected suite(s);
  else (Full)
    :Run smoke, UI, API, and E2E selections;
    :Preserve explicit skips instead of flaky failures;
  endif
  :Collect raw artifacts;
endif

:Write Surefire reports;
:Write Allure results;
stop

@enduml
