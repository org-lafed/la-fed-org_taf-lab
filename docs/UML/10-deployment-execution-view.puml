@startuml
title Deployment / Execution View

skinparam shadowing false

node "Developer Workstation" as DEV {
  artifact "Maven CLI" as MVN
  artifact "TestNG Suite XML" as SUITE
  artifact "TAF Lab classes" as CODE
  node "Local Browser\nChrome / Firefox / Edge" as BROWSER
}

node "GitHub Actions Runner" as CI {
  artifact "Workflow job" as JOB
  artifact "Maven" as CI_MVN
  artifact "Headless browser runtime" as CI_BROWSER
}

cloud "Automation Exercise UI" as WEB
cloud "Automation Exercise API" as API

database "Artifacts" as ART {
  artifact "target/allure-results" as ALLURE
  artifact "target/surefire-reports" as SUREFIRE
}

MVN --> SUITE
SUITE --> CODE
CODE --> BROWSER : UI execution
CODE --> API : API execution
BROWSER --> WEB : browser interactions

JOB --> CI_MVN
CI_MVN --> CODE
CODE --> CI_BROWSER : CI UI execution
CI_BROWSER --> WEB
CODE --> ALLURE
CODE --> SUREFIRE
CI_MVN --> ALLURE
CI_MVN --> SUREFIRE

@enduml
